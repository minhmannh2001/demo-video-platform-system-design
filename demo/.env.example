# Convenience: copy to .env and run `make run-api`, `make run-api-dev`, etc. (see Makefile).
#
# API
HTTP_ADDR=:8080
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_RAW_BUCKET=video-raw
S3_ENCODED_BUCKET=video-encoded
SQS_ENCODE_QUEUE_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/video-encode-jobs
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=video_demo
REDIS_ADDR=localhost:6379
REDIS_CACHE_TTL_SEC=300
# Must match the exact browser origin (scheme + host + port) of the web app.
# If you open the UI at http://192.168.x.x:5173, add that origin here.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Base URL the API returns in manifest_url (GET /watch). Use the same host clients use to reach the API.
PUBLIC_BASE_URL=http://localhost:8080

# Video search (Elasticsearch). Unset → GET /videos/search returns 503. In docker-compose, API uses http://elasticsearch:9200.
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_VIDEOS=videos
# Optional basic auth (leave empty for local single-node without security)
# ELASTICSEARCH_USERNAME=
# ELASTICSEARCH_PASSWORD=

# Metadata index fan-out (worker + API PATCH/delete). Example matches LocalStack queue from scripts/init-localstack.sh
SQS_VIDEO_METADATA_QUEUE_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/video-metadata-index

# OpenTelemetry (API + worker): see docs/TRACING.md
# OTEL_TRACING_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_TRACE_SAMPLING_ENABLED=true
# OTEL_TRACE_SAMPLE_RATIO=0.1

# Structured JSON logs (stdout): see docs/LOGGING.md
# LOG_LEVEL=info
# Optional: duplicate JSON to a file so Filebeat can ship logs when using `go run` (see docker-compose filebeat volume ./var/host-logs)
# LOG_FILE=var/host-logs/video-api.log

# Worker (same AWS/Mongo/Redis as API; needs ffmpeg on PATH)
# Run: go run ./worker/cmd/worker/
