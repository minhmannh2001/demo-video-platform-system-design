VITE_API_URL=http://localhost:8080

# Khớp WEBSOCKET_TOKEN trên API khi bật bảo vệ WS (?token= trên /ws)
# VITE_WEBSOCKET_TOKEN=

# Bước 6 — browser tracing (Jaeger). Cần jaeger + API OTel; Vite proxy /otel → :4318
# VITE_OTEL_TRACING_ENABLED=true
# VITE_OTEL_EXPORTER_URL=http://localhost:4318/v1/traces
# Tỷ lệ trace gốc (khớp OTEL_TRACE_SAMPLING_ENABLED trên API khi debug E2E)
# VITE_OTEL_TRACE_SAMPLING_ENABLED=true
# VITE_OTEL_TRACE_SAMPLE_RATIO=0.1
