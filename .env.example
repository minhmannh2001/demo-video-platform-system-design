# Copy to `.env` in this directory (repo root). Used by API, worker, and `go run ./cmd/search-backfill`.
# Frontend: see `web/.env.example` for VITE_* variables.
#
# All keys read by the Go apps (see `internal/config/config.go` + tracing/applog):
#   HTTP_*, AWS_*, S3_*, SQS_*, MONGODB_*, REDIS_*, CORS_ORIGINS, PUBLIC_BASE_URL,
#   ELASTICSEARCH_*, WEBSOCKET_TOKEN, WS_EVENT_CHANNEL,
#   OTEL_*, LOG_LEVEL, LOG_FILE
#
# API
HTTP_ADDR=:8080
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_RAW_BUCKET=video-raw
S3_ENCODED_BUCKET=video-encoded
SQS_ENCODE_QUEUE_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/video-encode-jobs
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=video_demo
REDIS_ADDR=localhost:6379
REDIS_CACHE_TTL_SEC=300
# GET /videos/search JSON cache in Redis (seconds). Same normalized q+page+filters share one key. 0 disables.
REDIS_SEARCH_CACHE_TTL_SEC=60
# Must match the exact browser origin (scheme + host + port) of the web app.
# If you open the UI at http://192.168.x.x:5173, add that origin here.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional WebSocket auth: non-empty requires ?token= on GET /ws (same value). Empty = dev open (still Origin-checked via CORS_ORIGINS).
# WEBSOCKET_TOKEN=
# Redis Pub/Sub channel for worker → API WebSocket events (empty = Hub in-process only; worker cannot push to browsers).
# Use the same value on API and worker (docker-compose sets video-demo:ws).
# WS_EVENT_CHANNEL=video-demo:ws
# Base URL the API returns in manifest_url (GET /watch). Use the same host clients use to reach the API.
PUBLIC_BASE_URL=http://localhost:8080

# Video search (Elasticsearch). Unset → GET /videos/search returns 503. In docker-compose, API uses http://elasticsearch:9200.
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_VIDEOS=videos
# Optional basic auth (leave empty for local single-node without security)
# ELASTICSEARCH_USERNAME=
# ELASTICSEARCH_PASSWORD=

# Metadata index fan-out (worker + API PATCH/delete). Example matches LocalStack queue from scripts/init-localstack.sh
SQS_VIDEO_METADATA_QUEUE_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/video-metadata-index

# OpenTelemetry (API + worker); Jaeger in docker-compose on :4318 / UI :16686
# OTEL_TRACING_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Optional: override service name (API/worker normally set video-api / video-worker in code)
# OTEL_SERVICE_NAME=video-api
# OTEL_TRACE_SAMPLING_ENABLED=true
# OTEL_TRACE_SAMPLE_RATIO=0.1

# Structured JSON logs (stdout); optional LOG_FILE for Filebeat host tail (compose mounts ./var/host-logs)
# LOG_LEVEL=info
# Optional: duplicate JSON to a file so Filebeat can ship logs when using `go run` (see docker-compose filebeat volume ./var/host-logs)
# LOG_FILE=var/host-logs/video-api.log

# Worker — uses the same variables as above (config.Load). Needs ffmpeg/ffprobe on PATH when not in Docker.
# Optional separate log file when running worker on host:
# LOG_FILE=var/host-logs/video-worker.log

# Elasticsearch integration tests only (go test -tags=integration ./internal/search/esclient/ ...)
# ELASTICSEARCH_INTEGRATION_URL=http://localhost:9200
# ELASTICSEARCH_INTEGRATION_USERNAME=
# ELASTICSEARCH_INTEGRATION_PASSWORD=
