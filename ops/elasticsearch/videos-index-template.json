{
  "index_patterns": ["videos", "videos-*"],
  "priority": 500,
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0
    },
    "mappings": {
      "_meta": {
        "description": "Full-text search for video catalog; separate from logs-* (Filebeat)."
      },
      "properties": {
        "video_id": {
          "type": "keyword"
        },
        "title": {
          "type": "text",
          "fields": {
            "keyword": {
              "type": "keyword",
              "ignore_above": 256
            }
          }
        },
        "description": {
          "type": "text",
          "fields": {
            "keyword": {
              "type": "keyword",
              "ignore_above": 2048
            }
          }
        },
        "owner_id": {
          "type": "keyword"
        },
        "encoding_status": {
          "type": "keyword"
        },
        "visibility": {
          "type": "keyword"
        },
        "created_at": {
          "type": "date"
        },
        "updated_at": {
          "type": "date"
        }
      }
    }
  }
}
